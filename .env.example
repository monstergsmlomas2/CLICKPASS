# ===== Clickpass — variables de entorno (backend) =====
# Copiar a apps/backend/.env y completar.

# --- Base de datos (Supabase Postgres) ---
# Monolito: una sola conexión; los schemas (clickpass_auth, clickpass_event, ...) separan dominios.
# Usar el SESSION pooler (puerto 5432): soporta transacciones interactivas (reserva con OCC).
# NO usar el transaction pooler (6543) como runtime.
DATABASE_URL="postgresql://postgres.TU_PROYECTO:TU_PASSWORD@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"
# Conexión directa para migraciones de Prisma (mismo 5432 en Supabase).
DIRECT_URL="postgresql://postgres.TU_PROYECTO:TU_PASSWORD@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"

# --- Redis: PENDIENTE (no lo da Supabase). Vacío = deshabilitado. Ej. Upstash cuando se sume. ---
REDIS_URL=

# --- MercadoPago (Checkout Pro, ARS). Vacío = modo SIMULADO. Con TEST-... = modo real. ---
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=

# --- JWT: access corto, refresh largo con rotación ---
JWT_SECRET=changeme-access-secret
JWT_REFRESH_SECRET=changeme-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- URLs ---
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001
PORT=3001

NODE_ENV=development
